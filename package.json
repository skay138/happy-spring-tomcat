{
  "name": "happy-spring-tomcat",
  "displayName": "Happy Spring Tomcat",
  "description": "Happy debugging for Spring projects (legacy) on Tomcat.",
  "publisher": "skay138",
  "version": "1.1.0",
  "icon": "icon.ico",
  "engines": {
    "vscode": "^1.80.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skay138/happy-spring-tomcat.git"
  },
  "bugs": {
    "url": "https://github.com/skay138/happy-spring-tomcat/issues"
  },
  "homepage": "https://github.com/skay138/happy-spring-tomcat/blob/main/README.md",
  "categories": [
    "Debuggers",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "spring",
    "tomcat",
    "legacy",
    "debug",
    "scaffold"
  ],
  "activationEvents": [
    "workspaceContains:pom.xml",
    "workspaceContains:build.gradle",
    "workspaceContains:**/WEB-INF/web.xml"
  ],
  "extensionDependencies": [
    "vscjava.vscode-java-debug"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "happy-spring-tomcat.setup",
        "title": "%commands.setup.title%"
      },
      {
        "command": "happy-spring-tomcat.restart",
        "title": "%commands.restart.title%"
      },
      {
        "command": "happy-spring-tomcat.showMenu",
        "title": "%commands.showMenu.title%"
      }
    ],
    "configuration": [
      {
        "title": "%config.server.title%",
        "properties": {
          "happySpringTomcat.tomcatHome": {
            "type": "string",
            "format": "path",
            "default": "",
            "order": 1,
            "markdownDescription": "%config.tomcatHome.description%"
          },
          "happySpringTomcat.httpPort": {
            "type": "number",
            "default": 8080,
            "order": 2,
            "markdownDescription": "%config.httpPort.description%"
          },
          "happySpringTomcat.debugPort": {
            "type": "number",
            "default": 8000,
            "order": 3,
            "markdownDescription": "%config.debugPort.description%"
          },
          "happySpringTomcat.preLaunchBuild": {
            "type": "string",
            "default": "none",
            "order": 4,
            "enum": ["none", "maven", "gradle"],
            "markdownDescription": "%config.preLaunchBuild.description%"
          },
          "happySpringTomcat.javaOpts": {
            "type": "string",
            "default": "-Dfile.encoding=UTF-8 -Dsun.stdout.encoding=UTF-8 -Dsun.stderr.encoding=UTF-8",
            "order": 5,
            "markdownDescription": "%config.javaOpts.description%"
          },
          "happySpringTomcat.colorizeLogs": {
            "type": "boolean",
            "default": true,
            "order": 6,
            "markdownDescription": "%config.colorizeLogs.description%"
          },
          "happySpringTomcat.autoOpenBrowser": {
            "type": "boolean",
            "default": true,
            "order": 7,
            "markdownDescription": "%config.autoOpenBrowser.description%"
          },
          "happySpringTomcat.showStatusBar": {
            "type": "boolean",
            "default": true,
            "order": 8,
            "markdownDescription": "%config.showStatusBar.description%"
          }
        }
      },
      {
        "title": "%config.deployment.title%",
        "properties": {
          "happySpringTomcat.contextPath": {
            "type": "string",
            "default": "",
            "order": 10,
            "markdownDescription": "%config.contextPath.description%"
          },
          "happySpringTomcat.docBase": {
            "type": "string",
            "format": "path",
            "default": "${workspaceFolder}/target/exploded",
            "order": 11,
            "markdownDescription": "%config.docBase.description%"
          }
        }
      },
      {
        "title": "%config.hotReload.title%",
        "properties": {
          "happySpringTomcat.sourceBase": {
            "type": "string",
            "format": "path",
            "default": "${workspaceFolder}/src/main/webapp",
            "order": 20,
            "markdownDescription": "%config.sourceBase.description%"
          },
          "happySpringTomcat.classesBase": {
            "type": "string",
            "format": "path",
            "default": "${workspaceFolder}/target/classes",
            "order": 21,
            "markdownDescription": "%config.classesBase.description%"
          }
        }
      },
      {
        "title": "%config.jndi.title%",
        "properties": {
          "happySpringTomcat.jndiResources": {
            "type": "array",
            "default": [],
            "order": 30,
            "markdownDescription": "%config.jndiResources.description%",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "description": "JNDI name (e.g. jdbc/myDataSource)" },
                "auth": { "type": "string", "default": "Container" },
                "type": { "type": "string", "default": "javax.sql.DataSource" },
                "factory": { "type": "string", "description": "DataSource factory class" },
                "driverClassName": { "type": "string", "description": "JDBC driver class" },
                "url": { "type": "string", "description": "JDBC connection URL" },
                "username": { "type": "string" },
                "password": { "type": "string" },
                "maxActive": { "type": ["string", "number"], "default": "100" },
                "maxIdle": { "type": ["string", "number"], "default": "50" },
                "maxWait": { "type": ["string", "number"], "default": "-1" }
              },
              "additionalProperties": { "type": "string" },
              "required": ["name"]
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@vscode/vsce": "^2.19.0"
  }
}
